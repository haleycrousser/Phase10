{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Server",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "server.cpp",
                "gameLoop/card.cpp",
                "gameLoop/deck.cpp",
                "gameLoop/player.cpp",
                "gameLoop/game.cpp",
                "gameLoop/phase.cpp",
                "csapp/csapp.cpp",
                "-lws2_32",
                "-g",
                "-o",
                "server.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build Client",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "client.cpp",
                "csapp/csapp.cpp",
                "-lws2_32",
                "-g",
                "-o",
                "client.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build All",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "C:/msys64/ucrt64/bin/g++.exe server.cpp gameLoop/card.cpp gameLoop/deck.cpp gameLoop/player.cpp gameLoop/game.cpp gameLoop/phase.cpp csapp/csapp.cpp -lws2_32 -g -o server.exe; C:/msys64/ucrt64/bin/g++.exe client.cpp csapp/csapp.cpp -lws2_32 -g -o client.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}